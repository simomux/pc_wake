# Pi + Mac config (used by pi/app.py and scripts/wake.sh)
# Arduino credentials go in arduino/main/config.h — not here

# Arduino static IP in LAN (must match LOCAL_IP in config.h)
ARDUINO_IP=

# Windows PC static IP in LAN
WIN_PC_IP=

# Tailscale IP of the Pi (run `tailscale status` on the Pi to find it)
PI_TAILSCALE_IP=
