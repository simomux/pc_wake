# Pi + Mac config (used by pi/app.py and scripts/wake.sh)
# Note: Arduino has its own config — see arduino/main/config.h.example

# WiFi SSID (2.4GHz, shared by Pi and Arduino)
WIFI_SSID=
WIFI_PASSWORD=

# Arduino static IP (must match LOCAL_IP in arduino/main/config.h)
ARDUINO_IP=

# Windows login (used by the Arduino HID keyboard)
WIN_USERNAME=
WIN_PASSWORD=
WIN_BOOT_DELAY=35

# Tailscale IP of the Pi (run `tailscale status` on the Pi to find it)
PI_TAILSCALE_IP=
